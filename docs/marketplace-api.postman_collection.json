{
  "info": {
    "name": "Multi-Vendor Marketplace API",
    "description": "Auth, vendor management, product management, and basic Week 2 endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"role\": \"customer\"\n}"
            }
          }
        },
        {
          "name": "Register Vendor",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vendor Name\",\n  \"email\": \"vendor@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"role\": \"vendor\",\n  \"store_name\": \"My Awesome Store\",\n  \"store_description\": \"Best products in town.\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.token) pm.collectionVariables.set('token', r.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@marketplace.com\",\n  \"password\": \"Admin@12345\"\n}"
            }
          }
        },
        {
          "name": "Login Vendor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.token) pm.collectionVariables.set('token', r.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendor@marketplace.com\",\n  \"password\": \"Vendor@12345\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/forgot-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@marketplace.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/reset-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_TOKEN_FROM_EMAIL\",\n  \"email\": \"admin@marketplace.com\",\n  \"password\": \"NewPassword@123\",\n  \"password_confirmation\": \"NewPassword@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Public Catalog",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Show Category",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/1",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Show Product",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/1",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Vendor",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/vendor/dashboard",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/vendor/profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/vendor/profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store_name\": \"Demo Store\",\n  \"description\": \"Updated store description\",\n  \"phone\": \"0600000000\",\n  \"city\": \"Casablanca\",\n  \"country\": \"Morocco\"\n}"
            }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/vendor/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/vendor/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Product\",\n  \"description\": \"Produit de test Week 2\",\n  \"price\": 199,\n  \"quantity\": 10,\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Show Product",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/vendor/products/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/vendor/products/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product\",\n  \"price\": 249,\n  \"quantity\": 15,\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/vendor/products/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Add Product Images",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/vendor/products/1/images",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "images[]", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Delete Product Image",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/vendor/products/1/images/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/dashboard",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "List Vendors",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/vendors",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Show Vendor",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/vendors/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Approve Vendor",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/vendors/1/approve",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Reject Vendor",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/vendors/1/reject",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Missing store information\"\n}"
            }
          }
        },
        {
          "name": "Suspend Vendor",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/vendors/1/suspend",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Policy issue\"\n}"
            }
          }
        },
        {
          "name": "Reactivate Vendor",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/vendors/1/reactivate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic products\",\n  \"is_active\": true,\n  \"sort_order\": 1\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/categories/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics Updated\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/categories/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    }
  ]
}
